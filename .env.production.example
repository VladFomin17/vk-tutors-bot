APP_ENV=production
APP_TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO

POSTGRES_DB=vk_tutors
POSTGRES_USER=vk_tutors
POSTGRES_PASSWORD=replace-with-openssl-rand-hex-32
DATABASE_URL=postgresql+asyncpg://vk_tutors:replace-with-the-same-hex-value@postgres:5432/vk_tutors

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-another-openssl-rand-hex-32
SESSION_COOKIE_NAME=vk_tutors_session
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=true

VK_GROUP_ID=
VK_ACCESS_TOKEN=
VK_API_VERSION=5.199
VK_LONG_POLL_WAIT_SECONDS=25
VK_REQUEST_TIMEOUT_SECONDS=10
VK_MAX_RETRIES=5
OUTBOX_POLL_SECONDS=10
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=5

MEDIA_ROOT=/data/media
MAX_ATTACHMENT_BYTES=10485760
VITE_API_URL=/api/v1

DOMAIN=admin.example.com
HEALTHCHECK_URL=https://admin.example.com/api/v1/health/ready
DISK_USAGE_LIMIT=85
BACKUP_RETENTION_DAYS=14
