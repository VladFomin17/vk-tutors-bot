APP_ENV=development
APP_TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO
TRUSTED_ORIGINS=http://localhost

POSTGRES_DB=vk_tutors
POSTGRES_USER=vk_tutors
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://vk_tutors:change-me@postgres:5432/vk_tutors

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=
SESSION_COOKIE_NAME=vk_tutors_session
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=false

VK_GROUP_ID=
VK_ACCESS_TOKEN=
VK_API_VERSION=5.199
VK_LONG_POLL_WAIT_SECONDS=25
VK_REQUEST_TIMEOUT_SECONDS=10
VK_MAX_RETRIES=5

MEDIA_ROOT=/data/media
MAX_ATTACHMENT_BYTES=10485760
EXPORT_MAX_RECIPIENTS=2000

VITE_API_URL=/api/v1
